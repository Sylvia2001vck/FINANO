# ========== 生产 / 服务器 ==========
# 在「项目根目录」（与 docker-compose.yml 同级）复制本文件为 .env 并填写。
# 不要用课程里的示例密钥；SECRET_KEY 请换成长随机串（openssl rand -hex 32）。
# DASHSCOPE_API_KEY、百度 OCR 等按需填写。
#
# CORS_ORIGINS：浏览器里打开前端的「完整来源」，JSON 数组字符串。
# 例：仅 IP 访问 → ["http://你的服务器IP"]
# 有域名后追加 → ["http://你的服务器IP","https://你的域名"]
# 否则前端调 /api 会被浏览器跨域拦截。

MYSQL_ROOT_PASSWORD=请改成强密码并与下方 DATABASE_URL 中 root:密码 一致
MYSQL_DATABASE=finano

# Docker Compose：host 必须是服务名 mysql（与 compose 里服务名一致）
DATABASE_URL=mysql+pymysql://root:请改成与MYSQL_ROOT_PASSWORD一致@mysql:3306/finano

# 本机不用 Docker、直接 uvicorn 时可用 SQLite（见 backend/.env.example）
# DATABASE_URL=sqlite:///./finano.db

SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

BAIDU_OCR_APP_ID=
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

DASHSCOPE_API_KEY=
FINANCE_MODEL_NAME=qwen3.6-plus
QWEN_FINANCE_MODEL=qwen3.6-plus

MAFB_LLM_MODE=auto

LOCAL_FINANCE_MODEL_ID=Qwen/Qwen1.8B-Chat
LOCAL_FINANCE_LLM_ENABLED=true
LOCAL_FINANCE_MAX_NEW_TOKENS=384

DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

OLLAMA_BASE_URL=
OLLAMA_MODEL=

CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

FUND_LIVE_QUOTE_ENABLED=true
