# ========== 生产 / 服务器 ==========
# 在「项目根目录」（与 docker-compose.yml 同级）复制本文件为 .env 并填写。
# 不要用课程里的示例密钥；SECRET_KEY 请换成长随机串（openssl rand -hex 32）。
# DASHSCOPE_API_KEY、百度 OCR 等按需填写。
#
# CORS_ORIGINS：浏览器里打开前端的「完整来源」，JSON 数组字符串（含端口则必须写上）。
# 例：compose 映射 8081:80 → ["http://你的服务器IP:8081"]
# 有域名后追加 → ["http://你的服务器IP:8081","https://你的域名"]
# 否则前端调 /api 会被浏览器跨域拦截。

MYSQL_ROOT_PASSWORD=请改成强密码并与下方 DATABASE_URL 中 root:密码 一致
MYSQL_DATABASE=finano

# Docker Compose：host 必须是服务名 mysql（与 compose 里服务名一致）
DATABASE_URL=mysql+pymysql://root:请改成与MYSQL_ROOT_PASSWORD一致@mysql:3306/finano

# 本机不用 Docker、直接 uvicorn 时可用 SQLite（见 backend/.env.example）
# DATABASE_URL=sqlite:///./finano.db

SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

BAIDU_OCR_APP_ID=
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

DASHSCOPE_API_KEY=
# 国际/新加坡百炼控制台创建的 Key：须走国际域名（二选一）
# DASHSCOPE_USE_INTL=true
# 或显式：DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com
DASHSCOPE_USE_INTL=false
DASHSCOPE_BASE_URL=
FINANCE_MODEL_NAME=qwen-plus
QWEN_FINANCE_MODEL=qwen-plus

MAFB_LLM_MODE=auto
# 并行打分智能体单次 LLM 上限（秒），超时走规则引擎，避免技术面等节点长时间卡住
# MAFB_AGENT_LLM_TIMEOUT_SEC=16
# 云端主模型（DashScope）单次调用硬超时，超时立即降级
# MAFB_CLOUD_PRIMARY_TIMEOUT_SEC=8
# 主模型协议不兼容时自动回退（建议保持 qwen-plus）
# MAFB_QWEN_FALLBACK_MODEL=qwen-plus
# qwen3 仅灰度/探针启用（主链路默认关闭，避免尾延迟放大）
# MAFB_QWEN3_GRAY_ENABLED=false
# qwen3 灰度名单（仅这些 Agent 可尝试 qwen3；其余强制回退 qwen-plus）
# MAFB_QWEN3_GRAY_AGENTS=profiling,kline
# 握手独立超时（建议 2~3 秒，失败立即降级）
# MAFB_LLM_HANDSHAKE_TIMEOUT_SEC=2.5
# 按 Agent 指定模型（留空=使用 FINANCE_MODEL_NAME；建议 fundamental/technical/risk 固定 qwen-plus）
# MAFB_MODEL_FUNDAMENTAL=qwen-plus
# MAFB_MODEL_TECHNICAL=qwen-plus
# MAFB_MODEL_RISK=qwen-plus
# MAFB_MODEL_PROFILING=qwen3.6-plus
# MAFB_MODEL_KLINE=qwen3.6-plus
# MAFB_MODEL_COMPLIANCE=qwen-plus
# 调试 JSON 解析问题时可临时放宽，例如：40 / 20
# MAFB_AGENT_LLM_TIMEOUT_SEC=40
# MAFB_CLOUD_PRIMARY_TIMEOUT_SEC=20
# 并行三智能体的 LLM 并发上限（云端常见 1 更稳，避免同模型并发排队超时）
# MAFB_LLM_MAX_CONCURRENCY=1
# K 线相似：预筛后对多少只基金拉历史净值（越大越慢，受 lsjz 节流影响）
# MAFB_KLINE_SIMILAR_MAX_NAV_FETCHES=64
# tiered：PAA 桶数、进入 DTW 精排的粗排前 M 名、DTW Sakoe-Chiba 相对带宽
# MAFB_KLINE_PAA_BINS=32
# MAFB_KLINE_FINE_POOL=48
# MAFB_KLINE_DTW_BAND_RATIO=0.18
# MAFB_KLINE_FINE_TIMEOUT_SEC=2.0

# 基金净值区间 lsjz-json：内存热缓存秒、过期后增量合并尾部（减轻东财重复翻页）
# FUND_LSJZ_HOT_TTL_SEC=180
# FUND_LSJZ_STALE_MAX_SEC=86400
# FUND_LSJZ_INCREMENTAL_MERGE=true
# FUND_LSJZ_HTTP_CACHE_MAX=512
# K8s 多副本建议配置 Redis（不配也可运行，自动回退进程内缓存）
# REDIS_URL=redis://redis-master.default.svc.cluster.local:6379/0
# REDIS_CACHE_PREFIX=finano
# REDIS_SOCKET_TIMEOUT_SEC=1.2
# 金融热点：后端定时聚合（建议 1 小时），客户端仅读统一快照缓存
# HOT_SCHEDULER_ENABLED=true
# HOT_REFRESH_INTERVAL_SEC=3600
# HOT_TOP_N=10
# HOT_CACHE_TTL_SEC=3900

LOCAL_FINANCE_MODEL_ID=Qwen/Qwen1.8B-Chat
LOCAL_FINANCE_LLM_ENABLED=true
LOCAL_FINANCE_MAX_NEW_TOKENS=384

DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

OLLAMA_BASE_URL=
OLLAMA_MODEL=

CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

FUND_LIVE_QUOTE_ENABLED=true

# 基金目录：static=内置演示池；eastmoney_full=启动后首次用到时从天天基金 fundcode_search.js 加载全市场索引（内存，约 2MB）
# FUND_CATALOG_MODE=eastmoney_full
